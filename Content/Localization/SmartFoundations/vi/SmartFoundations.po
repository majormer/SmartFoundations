msgctxt "SmartFoundations,P.BeltLevelMain.TT"
msgid "Belt tier for distributor-to-distributor (manifold) connections. Auto uses the highest tier you've unlocked."
msgstr "Cấp băng chuyền cho kết nối bộ phân phối với bộ phân phối (ống góp). Tự động dùng cấp cao nhất bạn đã mở khóa."

msgctxt "SmartFoundations,P.BeltLevelToBuilding"
msgid "Factory Belt"
msgstr "Băng chuyền nhà máy"

msgctxt "SmartFoundations,P.BeltLevelToBuilding.TT"
msgid "Belt tier for distributor-to-building connections. Auto uses the highest tier you've unlocked."
msgstr "Cấp băng chuyền cho kết nối bộ phân phối với tòa nhà. Tự động dùng cấp cao nhất bạn đã mở khóa."

msgctxt "SmartFoundations,P.BeltRoutingMode"
msgid "Belt Routing Mode"
msgstr "Chế độ định tuyến băng chuyền"

msgctxt "SmartFoundations,P.BeltRoutingMode.TT"
msgid "How auto-connected belts are shaped: Default, Curve, or Straight."
msgstr "Cách tạo hình băng chuyền tự động kết nối: Mặc định, Cong hoặc Thẳng."

msgctxt "SmartFoundations,P.HUDPositionX"
msgid "HUD Position X"
msgstr "Vị trí HUD ngang"

msgctxt "SmartFoundations,P.HUDPositionX.TT"
msgid "Horizontal position of the HUD on screen (0 = left edge, 1 = right edge)."
msgstr "Vị trí ngang của HUD trên màn hình (0 = mép trái, 1 = mép phải)."

msgctxt "SmartFoundations,P.HUDPositionY"
msgid "HUD Position Y"
msgstr "Vị trí HUD dọc"

msgctxt "SmartFoundations,P.HUDPositionY.TT"
msgid "Vertical position of the HUD on screen (0 = top, 1 = bottom)."
msgstr "Vị trí dọc của HUD trên màn hình (0 = trên, 1 = dưới)."

msgctxt "SmartFoundations,P.HUDScale"
msgid "HUD Scale"
msgstr "Tỷ lệ HUD"

msgctxt "SmartFoundations,P.HUDScale.TT"
msgid "Size of the Smart! HUD overlay."
msgstr "Kích thước của lớp phủ Smart! HUD."

msgctxt "SmartFoundations,P.HUDTheme"
msgid "HUD Theme"
msgstr "Chủ đề HUD"

msgctxt "SmartFoundations,P.HUDTheme.TT"
msgid "Color theme for the HUD: Default (FICSIT orange), Dark, Classic, High Contrast, Minimal, or Monochrome."
msgstr "Chủ đề màu cho HUD: Mặc định (cam FICSIT), Tối, Cổ điển, Tương phản cao, Tối thiểu hoặc Monochrome."

msgctxt "SmartFoundations,P.PipeIndicator"
msgid "Flow Indicator"
msgstr "Chỉ báo dòng chảy"

msgctxt "SmartFoundations,P.PipeIndicator.TT"
msgid "Show a flow-direction indicator on auto-connected pipes."
msgstr "Hiển thị chỉ báo hướng dòng chảy trên ống tự động kết nối."

msgctxt "SmartFoundations,P.PipeLevelMain"
msgid "Main Tier"
msgstr "Cấp chính"

msgctxt "SmartFoundations,P.PipeLevelMain.TT"
msgid "Pipe tier for the main connections. Auto uses the highest tier you've unlocked."
msgstr "Cấp ống cho kết nối chính. Tự động dùng cấp cao nhất bạn đã mở khóa."

msgctxt "SmartFoundations,P.PipeLevelToBuilding"
msgid "To Building"
msgstr "Đến tòa nhà"

msgctxt "SmartFoundations,P.PipeLevelToBuilding.TT"
msgid "Pipe tier for connections to buildings. Auto uses the highest tier you've unlocked."
msgstr "Cấp ống cho kết nối đến tòa nhà. Tự động dùng cấp cao nhất bạn đã mở khóa."

msgctxt "SmartFoundations,P.PipeRoutingMode"
msgid "Pipe Routing Mode"
msgstr "Chế độ định tuyến ống"

msgctxt "SmartFoundations,P.PipeRoutingMode.TT"
msgid "How auto-connected pipes are shaped: Auto, 2D, Straight, Curve, Noodle, or Horizontal-to-Vertical."
msgstr "Cách tạo hình ống tự động kết nối: Tự động, 2D, Thẳng, Cong, Mì hoặc Ngang sang Dọc."

msgctxt "SmartFoundations,P.PowerConnectMode"
msgid "Grid Axis"
msgstr "Trục lưới"

msgctxt "SmartFoundations,P.PowerConnectMode.TT"
msgid "Which directions power poles connect: Auto, X only, Y only, or both X and Y."
msgstr "Hướng các cột điện kết nối: Tự động, chỉ X, chỉ Y, hoặc cả X và Y."

msgctxt "SmartFoundations,P.PowerConnectRange"
msgid "Connection Range"
msgstr "Phạm vi kết nối"

msgctxt "SmartFoundations,P.PowerConnectRange.TT"
msgid "Maximum distance, in meters, to search for a power connection."
msgstr "Khoảng cách tối đa, tính bằng mét, để tìm kết nối điện."

msgctxt "SmartFoundations,P.PowerConnectReserved"
msgid "Connections to Keep Free"
msgstr "Kết nối dự trữ"

msgctxt "SmartFoundations,P.PowerConnectReserved.TT"
msgid "Number of pole connection slots to leave free for your own manual wiring."
msgstr "Số khe kết nối trên cột để dành cho việc đấu nối thủ công của bạn."

msgctxt "SmartFoundations,P.bApplyImmediately"
msgid "Apply Immediately"
msgstr "Áp dụng ngay"

msgctxt "SmartFoundations,P.bApplyImmediately.TT"
msgid "Apply Smart Panel changes instantly instead of clicking the Apply button."
msgstr "Áp dụng thay đổi Bảng Smart ngay lập tức thay vì nhấn nút Áp dụng."

msgctxt "SmartFoundations,P.bAutoConnectDistributors"
msgid "Use Manifold Lane Belts"
msgstr "Sử dụng băng chuyền ống góp"

msgctxt "SmartFoundations,P.bAutoConnectDistributors.TT"
msgid "Chain distributors together with manifold lane belts, so a whole row is fed from one input."
msgstr "Nối các bộ phân phối với nhau bằng băng chuyền ống góp, để cả một hàng được cấp từ một đầu vào."

msgctxt "SmartFoundations,P.bAutoConnectEnabled"
msgid "Belt Auto-Connect"
msgstr "Tự động kết nối băng chuyền"

msgctxt "SmartFoundations,P.bAutoConnectEnabled.TT"
msgid "Automatically connect conveyor belts between placed buildings and distributors."
msgstr "Tự động kết nối băng chuyền giữa các tòa nhà đã đặt và bộ phân phối."

msgctxt "SmartFoundations,P.bAutoHoldOnGridChange"
msgid "Auto-Hold on Grid Change"
msgstr "Tự động giữ khi thay đổi lưới"

msgctxt "SmartFoundations,P.bAutoHoldOnGridChange.TT"
msgid "Automatically lock the hologram in place after any grid change. Press the Hold key to release it."
msgstr "Tự động khóa ảnh ba chiều tại chỗ sau bất kỳ thay đổi lưới nào. Nhấn phím Giữ để thả."

msgctxt "SmartFoundations,P.bExtendDaisyChainPoleless"
msgid "Daisy-Chain Pole-less Factories"
msgstr "Đấu nối tiếp nhà máy không cột"

msgctxt "SmartFoundations,P.bExtendDaisyChainPoleless.TT"
msgid "When you Extend a factory that has no power pole and no existing daisy link (starting a fresh manifold), wire the new buildings together with daisy-chain power. Factories already daisy-chained are always continued regardless of this option."
msgstr "Khi bạn Mở rộng một nhà máy không có cột điện và không có liên kết nối tiếp sẵn (bắt đầu một ống góp mới), hãy đấu các tòa nhà mới với nhau bằng điện nối tiếp. Các nhà máy đã nối tiếp luôn được tiếp tục bất kể tùy chọn này."

msgctxt "SmartFoundations,P.bExtendDaisyChainPower"
msgid "Extend Daisy-Chain Power"
msgstr "Mở rộng điện nối tiếp"

msgctxt "SmartFoundations,P.bExtendDaisyChainPower.TT"
msgid "Once Upgraded Power Connectors is unlocked, Extend wires power directly building-to-building along the lane instead of running a pole to each building."
msgstr "Sau khi mở khóa Đầu nối điện nâng cấp, Mở rộng đấu điện trực tiếp giữa tòa nhà với tòa nhà dọc theo làn thay vì chạy một cột đến từng tòa nhà."

msgctxt "SmartFoundations,P.bExtendEnabled"
msgid "Extend Enabled"
msgstr "Bật mở rộng"

msgctxt "SmartFoundations,P.bExtendEnabled.TT"
msgid "Enable Extend - repeat a building or grid outward in one direction."
msgstr "Bật Mở rộng - lặp lại một tòa nhà hoặc lưới ra bên ngoài theo một hướng."

msgctxt "SmartFoundations,P.bExtendPowerEnabled"
msgid "Extend Power Poles"
msgstr "Mở rộng cột điện"

msgctxt "SmartFoundations,P.bExtendPowerEnabled.TT"
msgid "Include power poles when using Extend."
msgstr "Bao gồm cột điện khi dùng Mở rộng."

msgctxt "SmartFoundations,P.bPipeAutoConnectEnabled"
msgid "Pipe Auto-Connect"
msgstr "Tự động kết nối ống"

msgctxt "SmartFoundations,P.bPipeAutoConnectEnabled.TT"
msgid "Automatically connect pipes between placed buildings."
msgstr "Tự động kết nối ống giữa các tòa nhà đã đặt."

msgctxt "SmartFoundations,P.bPowerAutoConnectEnabled"
msgid "Power Auto-Connect"
msgstr "Tự động kết nối điện"

msgctxt "SmartFoundations,P.bPowerAutoConnectEnabled.TT"
msgid "Automatically wire power between placed buildings and nearby power poles."
msgstr "Tự động đấu điện giữa các tòa nhà đã đặt và cột điện gần đó."

msgctxt "SmartFoundations,P.bShowArrowLabels"
msgid "Arrow Axis Labels"
msgstr "Nhãn trục mũi tên"

msgctxt "SmartFoundations,P.bShowArrowLabels.TT"
msgid "Show X/Y/Z axis labels on the direction arrows."
msgstr "Hiển thị nhãn trục X/Y/Z trên mũi tên hướng."

msgctxt "SmartFoundations,P.bShowArrowOrbit"
msgid "Arrow Orbit Animation"
msgstr "Hoạt ảnh quỹ đạo mũi tên"

msgctxt "SmartFoundations,P.bShowArrowOrbit.TT"
msgid "Animate the arrows orbiting the hologram. Turn off for static arrows that still track you."
msgstr "Tạo hoạt ảnh mũi tên quay quanh ảnh ba chiều. Tắt để mũi tên tĩnh nhưng vẫn hướng theo bạn."

msgctxt "SmartFoundations,P.bShowArrows"
msgid "Show Direction Arrows"
msgstr "Hiển thị mũi tên hướng"

