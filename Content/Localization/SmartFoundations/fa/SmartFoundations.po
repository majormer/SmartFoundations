msgctxt "SmartFoundations,P.NearbyLogisticsRange.TT"
msgid "Maximum connector-to-connector distance for nearby factory belt and pipe Auto-Connect. Blueprint seams and manifold lanes are unaffected."
msgstr "بیشینه فاصله رابط تا رابط برای اتصال خودکار نوارها و لوله‌های کارخانه‌های نزدیک. درزهای نقشه و مسیرهای مانیفولد تأثیری نمی‌پذیرند."

msgctxt "SmartFoundations,P.bBlueprintSeamAutoConnectEnabled"
msgid "Blueprint Seam Auto-Connect"
msgstr "اتصال خودکار درز نقشه"

msgctxt "SmartFoundations,P.bBlueprintSeamAutoConnectEnabled.TT"
msgid "Connect belts and pipes across adjacent copies when scaling a blueprint, independently of nearby Belt and Pipe Auto-Connect."
msgstr "هنگام مقیاس‌بندی یک نقشه، نوارها و لوله‌ها را میان نسخه‌های مجاور متصل می‌کند؛ مستقل از اتصال خودکار نوارها و لوله‌های نزدیک."

msgctxt "SmartFoundations,P.bScaleDaisyChainPower"
msgid "Scale Daisy-Chain Power"
msgstr "زنجیره‌ای کردن برق هنگام مقیاس‌بندی"

msgctxt "SmartFoundations,P.bScaleDaisyChainPower.TT"
msgid "When Upgraded Power Connectors is unlocked, scaling factories and generators wires adjacent buildings together along the grid X axis."
msgstr "هنگامی که رابط‌های برق ارتقایافته باز شده باشند، مقیاس‌بندی کارخانه‌ها و مولدها ساختمان‌های مجاور را در امتداد محور X شبکه به هم سیم‌کشی می‌کند."

msgctxt "SmartFoundations,P.bToggleTransformModes"
msgid "Tap to Toggle Transform Modes"
msgstr "تعویض حالت‌های تبدیل با یک ضربه"

msgctxt "SmartFoundations,P.bToggleTransformModes.TT"
msgid "Tap a transform key (Spacing, Steps, Stagger, Rotation, or Recipe on a factory) to switch the mode on; tap it again to switch it off. Made for controllers and Steam Input radial menus, which cannot hold a key. Off keeps the normal hold-to-use behavior."
msgstr "برای روشن‌کردن حالت، روی یک کلید تبدیل (فاصله، پله‌ها، جابه‌جایی، چرخش، یا دستور روی یک کارخانه) ضربه بزنید؛ برای خاموش‌کردن دوباره ضربه بزنید. برای دسته‌ها و منوهای شعاعی Steam Input ساخته شده که نمی‌توانند کلید را نگه دارند. خاموش، رفتار عادی نگه‌داشتن را حفظ می‌کند."

msgctxt "SmartFoundations,Sec.AutoConnectBehavior"
msgid "Auto-Connect Behavior"
msgstr "رفتار اتصال خودکار"

msgctxt "SmartFoundations,Sec.AutoConnectBehavior.TT"
msgid "Controls behavior shared by nearby belt and pipe Auto-Connect."
msgstr "رفتار مشترک اتصال خودکار نوارها و لوله‌های نزدیک را کنترل می‌کند."

msgctxt "SmartFoundations,Sec.BlueprintAutoConnect"
msgid "Blueprint Auto-Connect"
msgstr "اتصال خودکار نقشه"

msgctxt "SmartFoundations,Sec.BlueprintAutoConnect.TT"
msgid "Controls connections between adjacent copies of scaled blueprints."
msgstr "اتصالات میان نسخه‌های مجاور نقشه‌های مقیاس‌بندی‌شده را کنترل می‌کند."
